---
import PseoShell from "../../components/pseo/PseoShell.astro";
import RelatedLinks from "../../components/pseo/RelatedLinks.astro";
import { terms, getTerm } from "../../data/glossary";
import { absUrl, faqSchema, SITE, type RelatedLink } from "../../lib/pseo";

export function getStaticPaths() {
  return terms.map((t) => ({ params: { term: t.slug } }));
}

const { term } = Astro.params;
const data = getTerm(term!)!;
const path = `/glossary/${data.slug}/`;

const crumbs = [
  { label: "Home", href: "/" },
  { label: "Glossary", href: "/glossary/" },
  { label: data.term, href: path },
];

const definedTerm = {
  "@type": "DefinedTerm",
  name: data.term,
  description: data.definition,
  inDefinedTermSet: {
    "@type": "DefinedTermSet",
    name: "Flowdira Glossary",
    url: `${SITE}/glossary/`,
  },
  url: absUrl(path),
};

const idx = terms.findIndex((t) => t.slug === data.slug);
const siblings = [1, 2, 3].map((n) => terms[(idx + n) % terms.length]);
const related: RelatedLink[] = [
  ...siblings.map((s) => ({
    label: `What is ${s.term.replace(/\s*\(.*\)\s*/, "")}?`,
    href: `/glossary/${s.slug}/`,
    note: s.category === "AI" ? "AI term" : "Web term",
  })),
  {
    label: "Headless vs traditional CMS",
    href: "/compare/headless-cms-vs-traditional-cms/",
    note: "Which to choose",
  },
  {
    label: "Website design by industry",
    href: "/web-design-for/",
    note: "Built for your sector",
  },
];
---

<PseoShell
  title={data.title}
  description={data.description}
  canonical={absUrl(path)}
  eyebrow={`${data.category} glossary`}
  h1={data.h1}
  lede={data.definition}
  crumbs={crumbs}
  schema={[definedTerm, faqSchema(data.faqs)]}
  ctaHeading="Want this built into your product?"
  ctaText="We design and integrate fast websites and real AI features — from RAG assistants to lightning-fast front-ends."
>
  <div class="pseo-body has-aside">
    <div class="pseo-prose" data-reveal>
      {data.body.map((p) => <p>{p}</p>)}

      <h2>Common questions</h2>
      <div class="pseo-faq">
        {
          data.faqs.map((f) => (
            <details>
              <summary>{f.q}</summary>
              <div class="pseo-faq__a">{f.a}</div>
            </details>
          ))
        }
      </div>
    </div>

    <aside class="pseo-aside">
      <div class="pseo-aside-cta">
        <h2>Build it with Flowdira</h2>
        <p>
          One studio for design, development and AI integration — we turn
          concepts like this into features your customers feel.
        </p>
        <a class="btn btn--blue btn--block" href="/#services">
          See our services
          <span class="btn__arrow">
            <svg viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path
                d="M4 12L12 4M12 4H6M12 4V10"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </span>
        </a>
      </div>
    </aside>
  </div>

  <RelatedLinks links={related} title="More from the glossary" />
</PseoShell>
