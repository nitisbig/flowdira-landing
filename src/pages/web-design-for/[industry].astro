---
import PseoShell from "../../components/pseo/PseoShell.astro";
import RelatedLinks from "../../components/pseo/RelatedLinks.astro";
import { industries, getIndustry } from "../../data/industries";
import { absUrl, faqSchema, SITE, type RelatedLink } from "../../lib/pseo";

export function getStaticPaths() {
  return industries.map((i) => ({ params: { industry: i.slug } }));
}

const { industry } = Astro.params;
const data = getIndustry(industry!)!;
const path = `/web-design-for/${data.slug}/`;

const crumbs = [
  { label: "Home", href: "/" },
  { label: "Web design for", href: "/web-design-for/" },
  { label: data.name, href: path },
];

const serviceSchema = {
  "@type": "Service",
  name: `Website design for ${data.audience}`,
  serviceType: "Web design, development & AI integration",
  description: data.description,
  provider: { "@id": `${SITE}/#org` },
  areaServed: ["United States", "Europe", "Australia"],
  url: absUrl(path),
};

// Internal linking — 3 sibling industries + a comparison, a glossary term, the hub.
const idx = industries.findIndex((i) => i.slug === data.slug);
const siblings = [1, 2, 3].map((n) => industries[(idx + n) % industries.length]);
const related: RelatedLink[] = [
  ...siblings.map((s) => ({
    label: `Web design for ${s.audience}`,
    href: `/web-design-for/${s.slug}/`,
    note: s.name,
  })),
  {
    label: "Custom website vs WordPress",
    href: "/compare/custom-website-vs-wordpress/",
    note: "Which is right for you?",
  },
  {
    label: "What is conversion rate optimization?",
    href: "/glossary/conversion-rate-optimization/",
    note: "The levers that lift conversions",
  },
  {
    label: "All industries we design for",
    href: "/web-design-for/",
    note: "Browse every sector",
  },
];
---

<PseoShell
  title={data.title}
  description={data.description}
  canonical={absUrl(path)}
  eyebrow="Industry"
  h1={`${data.h1Lead} ${data.h1Accent}`}
  lede={data.lede}
  crumbs={crumbs}
  schema={[serviceSchema, faqSchema(data.faqs)]}
  ctaHeading={`Ready to win more ${data.audience} online?`}
>
  <h1 slot="h1">{data.h1Lead} <span class="serif-italic">{data.h1Accent}</span></h1>

  <div class="pseo-body has-aside">
    <div class="pseo-prose" data-reveal>
      {data.intro.map((p) => <p>{p}</p>)}

      <h2>Where {data.name.toLowerCase()} lose visitors</h2>
      <div class="pseo-cards cols-2">
        {
          data.pains.map((p) => (
            <div class="pseo-card">
              <h3>{p.title}</h3>
              <p>{p.body}</p>
            </div>
          ))
        }
      </div>

      <h2>What we build for {data.audience}</h2>
      <div class="pseo-cards cols-2">
        {
          data.builds.map((b) => (
            <div class="pseo-card">
              <h3>{b.title}</h3>
              <p>{b.body}</p>
            </div>
          ))
        }
      </div>

      <h2>{data.name} website FAQs</h2>
      <div class="pseo-faq">
        {
          data.faqs.map((f) => (
            <details>
              <summary>{f.q}</summary>
              <div class="pseo-faq__a">{f.a}</div>
            </details>
          ))
        }
      </div>
    </div>

    <aside class="pseo-aside">
      <div class="pseo-aside-cta">
        <h2>One studio, start to live</h2>
        <p>
          Design, development and AI integration in one team — a fixed quote up
          front and a site built to convert.
        </p>
        <a class="btn btn--blue btn--block" href="/#contact">
          Start a project
          <span class="btn__arrow">
            <svg viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path
                d="M4 12L12 4M12 4H6M12 4V10"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </span>
        </a>
      </div>
    </aside>
  </div>

  <RelatedLinks links={related} />
</PseoShell>
