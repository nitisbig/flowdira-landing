---
/* Conversion band closing every programmatic page. Points at the
   home contact + work anchors (the real conversion surfaces). */
interface Props {
  heading?: string;
  text?: string;
}
const {
  heading = "Let's build something worth ranking.",
  text = "Design, development and AI integration from one studio — a fixed quote up front, shipped fast from GitHub to Vercel.",
} = Astro.props;
---

<section class="pseo-cta" data-reveal="scale">
  <h2 class="display">{heading}</h2>
  <p>{text}</p>
  <div class="pseo-cta__actions">
    <a class="btn btn--blue" href="/#contact">
      Start a project
      <span class="btn__arrow">
        <svg viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path
            d="M4 12L12 4M12 4H6M12 4V10"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </span>
    </a>
    <a class="btn btn--light" href="/#work">See our work</a>
  </div>
</section>
