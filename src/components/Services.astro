---
const services = [
  {
    num: "01",
    title: "Website Design",
    desc: "UI/UX and brand-driven website design that turns first impressions into trust. Wireframes, design systems, and pixel-perfect Figma files made to convert.",
    tags: ["UI/UX Design", "Design Systems", "Brand Identity", "Figma"],
    icon: `<rect x="3" y="3" width="18" height="18" rx="3"/><path d="M3 9h18M9 21V9"/>`,
    featured: false,
  },
  {
    num: "02",
    title: "Web Development",
    desc: "Fast, accessible front-end development in Astro, Next.js & React. Clean, maintainable code with headless CMS and 90+ Lighthouse scores out of the box.",
    tags: ["Astro", "Next.js", "Headless CMS", "Performance"],
    icon: `<path d="M8 6 3 12l5 6M16 6l5 6-5 6M13 4l-2 16"/>`,
    featured: false,
  },
  {
    num: "03",
    title: "AI Integration",
    desc: "AI woven into your product — chatbots, AI agents, RAG search and workflow automation using the latest LLMs. Smart features your customers actually feel.",
    tags: ["AI Agents", "Chatbots", "RAG Search", "Automation"],
    icon: `<path d="M12 3v3m0 12v3M3 12h3m12 0h3M6 6l2 2m8 8 2 2M6 18l2-2m8-8 2-2"/><circle cx="12" cy="12" r="3.2"/>`,
    featured: true,
  },
];
---

<section class="services section" id="services">
  <div class="container">
    <header class="services__head">
      <div data-reveal>
        <p class="eyebrow">What we do</p>
        <h2 class="services__title">
          Everything between<br />
          <span class="serif-italic">idea</span> and <span
            class="serif-italic">live.</span
          >
        </h2>
      </div>
      <p class="services__intro" data-reveal style="--reveal-delay: 90ms">
        One studio for design, development and AI integration — so your website
        looks sharp, loads fast, and works smarter. No handoffs, no gaps.
      </p>
    </header>

    <div class="services__grid">
      {
        services.map((s, i) => (
          <article
            class:list={["svc", { "svc--featured": s.featured }]}
            data-reveal
            style={`--reveal-delay: ${i * 110}ms`}
          >
            <div class="svc__top">
              <span class="svc__icon">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  set:html={s.icon}
                />
              </span>
              <span class="svc__num">{s.num}</span>
            </div>

            <h3 class="svc__title">{s.title}</h3>
            <p class="svc__desc">{s.desc}</p>

            <ul class="svc__tags">
              {s.tags.map((t) => (
                <li class="tag">{t}</li>
              ))}
            </ul>

            <a class="svc__link link-underline" href="#contact">
              Start here
              <svg viewBox="0 0 16 16" fill="none" width="13" height="13">
                <path
                  d="M4 12L12 4M12 4H6M12 4V10"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .services__head {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 2rem;
    align-items: end;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  .services__title {
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    margin-top: 1rem;
  }

  .services__title .serif-italic {
    color: var(--forest);
  }

  .services__intro {
    color: var(--muted);
    font-size: 1.05rem;
    max-width: 28rem;
    padding-bottom: 0.5rem;
  }

  .services__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .svc {
    display: flex;
    flex-direction: column;
    padding: 1.75rem;
    border-radius: var(--r-lg);
    background: var(--paper-raised);
    border: 1px solid var(--hairline);
    box-shadow: var(--shadow-card);
    transition: transform 0.5s var(--ease), box-shadow 0.5s var(--ease);
  }

  .svc:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-float);
  }

  .svc__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .svc__icon {
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    border-radius: var(--r-sm);
    background: var(--paper-sunk);
    color: var(--forest);
  }
  .svc__icon svg {
    width: 1.4rem;
    height: 1.4rem;
  }

  .svc__num {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--muted-2);
    letter-spacing: -0.02em;
  }

  .svc__title {
    font-size: 1.5rem;
    letter-spacing: -0.03em;
  }

  .svc__desc {
    margin: 0.75rem 0 1.5rem;
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.6;
    flex: 1;
  }

  .svc__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-bottom: 1.5rem;
  }

  .svc__link {
    font-size: 0.92rem;
    color: var(--forest);
    align-self: flex-start;
  }

  /* Featured (AI) — inverted forest card with brand-blue charge */
  .svc--featured {
    background:
      radial-gradient(120% 80% at 90% 0%, rgba(22, 160, 250, 0.28), transparent 55%),
      var(--forest);
    border-color: var(--forest-line);
    color: var(--on-forest);
  }
  .svc--featured .svc__icon {
    background: rgba(22, 160, 250, 0.16);
    color: var(--blue-bright);
  }
  .svc--featured .svc__num {
    color: var(--on-forest-mut);
  }
  .svc--featured .svc__desc {
    color: var(--on-forest-mut);
  }
  .svc--featured .tag {
    background: rgba(237, 231, 216, 0.1);
    border-color: rgba(237, 231, 216, 0.16);
    color: var(--on-forest);
  }
  .svc--featured .svc__link {
    color: var(--blue-bright);
  }

  @media (max-width: 880px) {
    .services__head {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
    .services__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
