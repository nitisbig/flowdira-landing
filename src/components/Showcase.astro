---
// Real, shipped work — live on Vercel, previewed with actual screenshots.
const projects = [
  {
    img: "/work/portfolio.webp",
    title: "Nitesh — Portfolio",
    cat: "Personal developer portfolio · Design + Build",
    repo: "nitisbig/portfolio-site",
    url: "https://portfolio-site-three-coral.vercel.app/",
    host: "portfolio-site-three-coral.vercel.app",
    platform: "vercel",
    tags: ["Astro", "Tailwind", "Editorial"],
  },
  {
    img: "/work/maintenance.webp",
    title: "The Maintenance Man",
    cat: "Home-services business site · Design + Build",
    repo: null,
    url: "https://themaintenanceman.vercel.app/",
    host: "themaintenanceman.vercel.app",
    platform: "vercel",
    tags: ["Responsive", "SEO", "Local business"],
  },
  {
    img: "/work/appointment.webp",
    title: "BrightSmile Dental",
    cat: "Dental booking experience · Design + Build",
    repo: "nitisbig/appointment-system",
    url: "https://appointment-system-vert-five.vercel.app/",
    host: "appointment-system-vert-five.vercel.app",
    platform: "vercel",
    tags: ["Next.js", "TypeScript", "Booking"],
  },
  {
    img: "/work/takeaway.webp",
    title: "Takeaways",
    cat: "Minimal notes app · Design + Build",
    repo: "nitisbig/takeaway",
    url: "https://takeaway-weld.vercel.app/",
    host: "takeaway-weld.vercel.app",
    platform: "vercel",
    tags: ["SvelteKit", "Supabase", "Vercel"],
  },
  {
    img: "/work/claude-guide.webp",
    title: "Claude Code Guide",
    cat: "Interactive learning app · Design + Build",
    repo: "nitisbig/claude-code-guide",
    url: "https://claude-code-guide-eosin-delta.vercel.app/",
    host: "claude-code-guide-eosin-delta.vercel.app",
    platform: "vercel",
    tags: ["Next.js", "TypeScript", "Education"],
  },
  {
    img: "/work/explorative.webp",
    title: "Explorative Giants",
    cat: "Philosophy reference · Design + Build",
    repo: "nitisbig/explorative-giants",
    url: "https://explorative-giants.vercel.app/",
    host: "explorative-giants.vercel.app",
    platform: "vercel",
    tags: ["Next.js", "TypeScript", "Tailwind"],
  },
  {
    img: "/work/interstellar.webp",
    title: "Interstellar — Gargantua",
    cat: "Audio-reactive WebGL visualizer · Build + Motion",
    repo: "nitisbig/interstellar",
    url: "https://interstellar-phi-eosin.vercel.app/",
    host: "interstellar-phi-eosin.vercel.app",
    platform: "vercel",
    tags: ["Canvas", "WebGL", "Audio-reactive"],
  },
];

const platformLabel = { vercel: "Vercel", cloudflare: "Cloudflare" };

// Split the editorial "category · role" line into its two parts so each entry
// reads like a catalogue listing — no invented copy, derived from real data.
const entries = projects.map((p, i) => {
  const [descriptor, role] = p.cat.split(" · ");
  return { ...p, descriptor, role: role ?? "", n: String(i + 1).padStart(2, "0") };
});
---

<section class="work section" id="work">
  <div class="container">
    <header class="work__head">
      <div data-reveal="left">
        <p class="eyebrow">Selected work</p>
        <h2 class="work__title">
          Shipped, not <span class="serif-italic">mocked up.</span>
        </h2>
      </div>

      <div class="work__aside" data-reveal="right">
        <p class="work__lede">
          Every piece below is live in production this minute — real code
          pushed to Git, built, and deployed. Step inside any of them.
        </p>

        <!-- push → build → live, the studio's actual pipeline -->
        <span class="pipeline" role="img" aria-label="Workflow: push to Git, build, live in production">
          <span class="pipeline__node">
            <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14" aria-hidden="true">
              <path
                d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.3.8-.6v-2c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z"
              ></path>
            </svg>
            Push
          </span>
          <span class="pipeline__line"></span>
          <span class="pipeline__node">
            <span class="pipeline__build" aria-hidden="true"></span>
            Build
          </span>
          <span class="pipeline__line"></span>
          <span class="pipeline__node pipeline__node--live">
            <svg viewBox="0 0 24 24" fill="currentColor" width="12" height="12" aria-hidden="true">
              <path d="M12 3 22 20H2L12 3Z"></path>
            </svg>
            Live
          </span>
        </span>
      </div>
    </header>

    <ol class="reel">
      {
        entries.map((p, i) => (
          <li
            class:list={["entry", { "entry--flip": i % 2 === 1 }]}
            data-reveal="scale"
          >
            <span class="entry__ghost" data-parallax aria-hidden="true">
              {p.n}
            </span>

            <a
              class="frame"
              href={p.url}
              target="_blank"
              rel="noopener"
              aria-label={`Open ${p.title} live in a new tab`}
            >
              <span class="frame__spot" aria-hidden="true" />

              <span class="frame__chrome">
                <span class="frame__dots" aria-hidden="true">
                  <i /><i /><i />
                </span>
                <span class="frame__addr">{p.host}</span>
                <span class="frame__live">
                  <span class="frame__pulse" aria-hidden="true" />
                  Live
                </span>
              </span>

              <span class="frame__shot">
                <img
                  src={p.img}
                  alt={`${p.title} — live site preview`}
                  width="1280"
                  height="800"
                  loading="lazy"
                  decoding="async"
                />
              </span>

              <span class="frame__cue" aria-hidden="true">
                <svg viewBox="0 0 16 16" fill="none" width="18" height="18">
                  <path
                    d="M4 12L12 4M12 4H6M12 4V10"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
            </a>

            <div class="entry__meta">
              <p class="entry__role">
                <span class="entry__index">{p.n}</span>
                {p.role}
              </p>

              <h3 class="entry__name">{p.title}</h3>
              <p class="entry__desc">{p.descriptor}</p>

              <ul class="entry__tags">
                {p.tags.map((t) => (
                  <li class="tag">{t}</li>
                ))}
              </ul>

              <div class="entry__foot">
                <a
                  class="entry__visit link-underline"
                  href={p.url}
                  target="_blank"
                  rel="noopener"
                  aria-label={`Visit ${p.title} live site`}
                >
                  View live site
                  <svg viewBox="0 0 16 16" fill="none" width="13" height="13" aria-hidden="true">
                    <path
                      d="M4 12L12 4M12 4H6M12 4V10"
                      stroke="currentColor"
                      stroke-width="1.7"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                </a>

                {p.repo && (
                  <a
                    class="entry__repo"
                    href={`https://github.com/${p.repo}`}
                    target="_blank"
                    rel="noopener"
                    aria-label={`View ${p.title} source on GitHub`}
                  >
                    <svg viewBox="0 0 24 24" fill="currentColor" width="13" height="13" aria-hidden="true">
                      <path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.3.8-.6v-2c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z" />
                    </svg>
                    <span class="entry__repo-name">{p.repo}</span>
                  </a>
                )}

                <span
                  class:list={["entry__plat", `entry__plat--${p.platform}`]}
                  title={`Deployed on ${platformLabel[p.platform]}`}
                >
                  <svg viewBox="0 0 24 24" fill="currentColor" width="11" height="11" aria-hidden="true">
                    <path d="M12 3 22 20H2L12 3Z" />
                  </svg>
                  {platformLabel[p.platform]}
                </span>
              </div>
            </div>
          </li>
        ))
      }
    </ol>

    <div class="work__cta" data-reveal>
      <a
        class="btn btn--ghost"
        href="https://github.com/nitisbig"
        target="_blank"
        rel="noopener"
      >
        Browse more on GitHub
        <span class="btn__arrow">
          <svg viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path
              d="M4 12L12 4M12 4H6M12 4V10"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </span>
      </a>
    </div>
  </div>
</section>

<style>
  /* contain the bleeding ghost numerals without a horizontal scrollbar */
  .work {
    overflow-x: clip;
  }

  /* ---------- header ---------- */
  .work__head {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 2rem clamp(2rem, 5vw, 4rem);
    align-items: end;
    margin-bottom: clamp(3rem, 7vw, 5.5rem);
  }
  .work__title {
    font-size: clamp(2.2rem, 5.5vw, 3.8rem);
    margin-top: 1rem;
  }
  .work__title .serif-italic {
    color: var(--blue);
  }
  .work__aside {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.4rem;
    padding-bottom: 0.4rem;
  }
  .work__lede {
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.6;
    max-width: 32rem;
  }

  /* ---------- push → build → live chip ---------- */
  .pipeline {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.6rem 0.95rem;
    background: var(--paper-raised);
    border: 1px solid var(--hairline);
    border-radius: var(--r-pill);
    box-shadow: var(--shadow-card);
  }
  .pipeline__node {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    font-weight: 560;
    color: var(--ink-2);
  }
  .pipeline__node--live {
    color: var(--blue);
    font-weight: 640;
  }
  .pipeline__line {
    width: 1.4rem;
    height: 1px;
    background: var(--line-strong);
    position: relative;
    overflow: hidden;
  }
  .pipeline__line::after {
    content: "";
    position: absolute;
    inset: 0;
    width: 40%;
    background: var(--blue);
    animation: flow 2.4s var(--ease) infinite;
  }
  @keyframes flow {
    from {
      transform: translateX(-100%);
    }
    to {
      transform: translateX(350%);
    }
  }
  .pipeline__build {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 50%;
    border: 2px solid var(--blue);
    border-top-color: transparent;
    animation: spin 1s linear infinite;
  }
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  /* ---------- the reel ---------- */
  .reel {
    display: flex;
    flex-direction: column;
    gap: clamp(4rem, 9vw, 7.5rem);
  }

  .entry {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1.75rem, 4.5vw, 4rem);
    align-items: center;
  }

  /* alternating composition — even rows mirror */
  .entry--flip .frame {
    order: 2;
  }
  .entry--flip .entry__meta {
    order: 1;
  }

  /* giant catalogue numeral bleeding behind the listing */
  .entry__ghost {
    position: absolute;
    top: -0.46em;
    right: -0.06em;
    z-index: 0;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(7rem, 15vw, 14rem);
    line-height: 0.8;
    letter-spacing: -0.05em;
    color: var(--forest);
    opacity: 0.05;
    pointer-events: none;
    user-select: none;
  }
  .entry--flip .entry__ghost {
    right: auto;
    left: -0.06em;
  }

  /* ---------- live browser frame ---------- */
  .frame {
    position: relative;
    display: block;
    z-index: 1;
    border-radius: var(--r-lg);
    background: var(--paper-raised);
    border: 1px solid var(--hairline);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    transition: transform 0.6s var(--ease), box-shadow 0.6s var(--ease),
      border-color 0.6s var(--ease);
  }
  .frame:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-float), var(--blue-glow);
    border-color: var(--blue-line);
  }

  /* pointer-tracking spotlight (JS-fed; harmless without it) */
  .frame__spot {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    opacity: 0;
    background: radial-gradient(
      460px circle at var(--mx, 50%) var(--my, 50%),
      rgba(10, 114, 247, 0.16),
      transparent 60%
    );
    transition: opacity 0.4s var(--ease);
  }
  .frame:hover .frame__spot {
    opacity: 1;
  }

  .frame__chrome {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 0.85rem;
    background: color-mix(in srgb, var(--ink) 5%, transparent);
    border-bottom: 1px solid var(--hairline);
  }
  .frame__dots {
    display: flex;
    gap: 0.28rem;
    flex-shrink: 0;
  }
  .frame__dots i {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: var(--line-strong);
  }
  .frame__addr {
    flex: 1;
    min-width: 0;
    font-size: 0.66rem;
    color: var(--muted);
    letter-spacing: -0.01em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .frame__live {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    flex-shrink: 0;
    font-size: 0.64rem;
    font-weight: 640;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--blue);
  }
  .frame__pulse {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: var(--blue);
    animation: pulse 2.4s var(--ease) infinite;
  }
  @keyframes pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(10, 114, 247, 0.5);
    }
    70% {
      box-shadow: 0 0 0 0.5rem rgba(10, 114, 247, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(10, 114, 247, 0);
    }
  }

  .frame__shot {
    display: block;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--paper-sunk);
  }
  .frame__shot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    transition: transform 0.8s var(--ease);
  }
  .frame:hover .frame__shot img {
    transform: scale(1.045);
  }

  .frame__cue {
    position: absolute;
    bottom: 0.85rem;
    right: 0.85rem;
    z-index: 4;
    display: grid;
    place-items: center;
    width: 2.8rem;
    height: 2.8rem;
    border-radius: 50%;
    color: #fff;
    background: var(--blue-grad);
    box-shadow: var(--blue-glow);
    opacity: 0;
    transform: translateY(10px) scale(0.85);
    transition: opacity 0.45s var(--ease), transform 0.45s var(--ease-spring);
  }
  .frame:hover .frame__cue {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  /* ---------- editorial meta ---------- */
  .entry__meta {
    position: relative;
    z-index: 1;
  }
  .entry__role {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .entry__index {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0;
    color: var(--blue);
  }
  .entry__name {
    margin-top: 0.85rem;
    font-size: clamp(1.8rem, 3.6vw, 2.9rem);
    letter-spacing: -0.03em;
  }
  .entry__desc {
    margin-top: 0.7rem;
    font-size: 1.02rem;
    line-height: 1.55;
    color: var(--muted);
    max-width: 26rem;
  }
  .entry__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 1.4rem;
  }

  .entry__foot {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.85rem 1.4rem;
    margin-top: 1.6rem;
  }
  .entry__visit {
    font-size: 0.95rem;
    font-weight: 560;
    color: var(--blue);
  }
  .entry__repo {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    max-width: 100%;
    min-width: 0;
    padding: 0.4rem 0.75rem;
    font-size: 0.78rem;
    color: var(--ink-2);
    background: var(--paper-sunk);
    border: 1px solid var(--hairline);
    border-radius: var(--r-pill);
    transition: color 0.3s var(--ease), border-color 0.3s var(--ease),
      background 0.3s var(--ease);
  }
  .entry__repo svg {
    flex-shrink: 0;
  }
  .entry__repo-name {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
  }
  .entry__repo:hover {
    color: var(--blue);
    border-color: var(--blue-line);
    background: var(--blue-soft);
  }
  .entry__plat {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-left: auto;
    font-size: 0.74rem;
    font-weight: 600;
    color: var(--blue);
    white-space: nowrap;
  }
  .entry__plat--cloudflare {
    color: var(--gold-deep);
  }

  .work__cta {
    display: flex;
    justify-content: center;
    margin-top: clamp(3.5rem, 7vw, 5.5rem);
  }

  /* ---------- responsive ---------- */
  @media (max-width: 860px) {
    .work__head {
      grid-template-columns: 1fr;
      align-items: start;
      gap: 1.5rem;
    }
    .entry {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    /* stack preview-first regardless of parity */
    .entry--flip .frame,
    .entry--flip .entry__meta {
      order: 0;
    }
    .entry__ghost {
      top: -0.34em;
      right: 0;
      font-size: clamp(5.5rem, 24vw, 9rem);
      opacity: 0.06;
    }
    .entry--flip .entry__ghost {
      left: auto;
      right: 0;
    }
    .entry__plat {
      margin-left: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .frame:hover {
      transform: none;
    }
    .frame:hover .frame__shot img {
      transform: none;
    }
  }
</style>

<script>
  // Premium hover layer: a soft pointer-tracking spotlight on each live frame.
  // Skipped on touch / reduced-motion so it never gets in the way.
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const fine = window.matchMedia("(hover: hover) and (pointer: fine)").matches;

  if (!reduce && fine) {
    const frames = document.querySelectorAll<HTMLElement>(".work .frame");
    frames.forEach((frame) => {
      const spot = frame.querySelector<HTMLElement>(".frame__spot");
      if (!spot) return;
      frame.addEventListener("pointermove", (e: PointerEvent) => {
        const r = frame.getBoundingClientRect();
        spot.style.setProperty("--mx", `${((e.clientX - r.left) / r.width) * 100}%`);
        spot.style.setProperty("--my", `${((e.clientY - r.top) / r.height) * 100}%`);
      });
    });
  }
</script>
