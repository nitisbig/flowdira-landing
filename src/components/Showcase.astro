<script>
  // Premium hover layer: pointer-tracking spotlight + subtle 3D tilt.
  // Skipped entirely for touch / reduced-motion so it never gets in the way.
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const fine = window.matchMedia("(hover: hover) and (pointer: fine)").matches;

  if (!reduce && fine) {
    const cards = document.querySelectorAll<HTMLElement>("[data-tilt]");
    cards.forEach((card) => {
      const inner = card.querySelector<HTMLElement>(".proj__inner");
      const spot = card.querySelector<HTMLElement>(".proj__spot");
      const MAX = 5; // degrees

      const onMove = (e: PointerEvent) => {
        const r = card.getBoundingClientRect();
        const px = (e.clientX - r.left) / r.width;
        const py = (e.clientY - r.top) / r.height;
        if (inner) {
          inner.style.setProperty("--ry", `${(px - 0.5) * MAX * 2}deg`);
          inner.style.setProperty("--rx", `${(0.5 - py) * MAX * 2}deg`);
        }
        if (spot) {
          spot.style.setProperty("--mx", `${px * 100}%`);
          spot.style.setProperty("--my", `${py * 100}%`);
        }
      };
      const reset = () => {
        if (!inner) return;
        inner.style.setProperty("--rx", "0deg");
        inner.style.setProperty("--ry", "0deg");
      };

      card.addEventListener("pointermove", onMove);
      card.addEventListener("pointerleave", reset);
    });
  }
</script>
