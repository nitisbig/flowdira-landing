---
import BrandMark from "./BrandMark.astro";

const projects = [
  {
    theme: "commerce",
    title: "Northwind Commerce",
    cat: "Headless e-commerce · Design + Build",
    repo: "flowdira/northwind-commerce",
    tags: ["Next.js", "Stripe", "Vercel"],
    speed: "0.4s",
    score: "100",
  },
  {
    theme: "ai",
    title: "Lumen AI",
    cat: "AI SaaS dashboard · AI Integration",
    repo: "flowdira/lumen-ai",
    tags: ["Astro", "AI SDK", "RAG"],
    speed: "0.6s",
    score: "99",
  },
  {
    theme: "studio",
    title: "Verdant Studio",
    cat: "Editorial portfolio · Design + Build",
    repo: "flowdira/verdant-studio",
    tags: ["Astro", "Sanity CMS", "Vercel"],
    speed: "0.3s",
    score: "100",
  },
  {
    theme: "analytics",
    title: "Pulse Analytics",
    cat: "Realtime dashboard · Build + AI",
    repo: "flowdira/pulse-analytics",
    tags: ["React", "D3", "Edge"],
    speed: "0.5s",
    score: "98",
  },
];
---

<section class="work section" id="work">
  <div class="container">
    <header class="work__head">
      <div data-reveal>
        <p class="eyebrow">Selected work</p>
        <h2 class="work__title">
          Designed, built &amp; <span class="serif-italic">deployed.</span>
        </h2>
      </div>

      <!-- GitHub → Vercel pipeline -->
      <div class="pipeline" data-reveal style="--reveal-delay: 80ms">
        <span class="pipeline__node">
          <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
            <path
              d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.3.8-.6v-2c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z"
            ></path>
          </svg>
          Push
        </span>
        <span class="pipeline__line"></span>
        <span class="pipeline__node">
          <span class="pipeline__build"></span>
          Build
        </span>
        <span class="pipeline__line"></span>
        <span class="pipeline__node pipeline__node--live">
          <svg viewBox="0 0 24 24" fill="currentColor" width="13" height="13">
            <path d="M12 3 22 20H2L12 3Z"></path>
          </svg>
          Live on Vercel
        </span>
      </div>
    </header>

    <div class="work__grid">
      {
        projects.map((p, i) => (
          <article class="proj" data-reveal style={`--reveal-delay: ${i * 90}ms`}>
            <div class:list={["proj__preview", `t-${p.theme}`]}>
              <div class="proj__chrome">
                <span class="proj__dots">
                  <i /><i /><i />
                </span>
                <span class="proj__addr">{p.repo.split("/")[1]}.vercel.app</span>
              </div>

              <div class="proj__screen">
                {p.theme === "commerce" && (
                  <div class="m-commerce">
                    <div class="m-bar">
                      <span class="m-brand">
                        <BrandMark size={10} /> Northwind
                      </span>
                      <span class="m-cart" />
                    </div>
                    <div class="m-grid">
                      <span /><span /><span /><span /><span /><span />
                    </div>
                  </div>
                )}
                {p.theme === "ai" && (
                  <div class="m-ai">
                    <div class="m-side">
                      <span /><span /><span />
                    </div>
                    <div class="m-chat">
                      <span class="m-msg m-msg--in" />
                      <span class="m-msg m-msg--out" />
                      <span class="m-msg m-msg--in m-msg--sm" />
                      <span class="m-prompt" />
                    </div>
                  </div>
                )}
                {p.theme === "studio" && (
                  <div class="m-studio">
                    <span class="m-eyebrow" />
                    <p class="m-headline">Make it<br />unforgettable</p>
                    <div class="m-thumbs">
                      <span /><span /><span />
                    </div>
                  </div>
                )}
                {p.theme === "analytics" && (
                  <div class="m-analytics">
                    <div class="m-stats">
                      <span /><span /><span />
                    </div>
                    <div class="m-chart">
                      <i style="height:40%" /><i style="height:70%" />
                      <i style="height:55%" /><i style="height:90%" />
                      <i style="height:65%" /><i style="height:100%" />
                    </div>
                  </div>
                )}
              </div>

              <span class="proj__deploy">
                <svg viewBox="0 0 24 24" fill="currentColor" width="10" height="10">
                  <path d="M12 3 22 20H2L12 3Z" />
                </svg>
                Ready
              </span>
            </div>

            <div class="proj__meta">
              <div class="proj__line">
                <h3 class="proj__name">{p.title}</h3>
                <a class="proj__visit" href="#contact" aria-label={`Visit ${p.title}`}>
                  <svg viewBox="0 0 16 16" fill="none" width="14" height="14">
                    <path
                      d="M4 12L12 4M12 4H6M12 4V10"
                      stroke="currentColor"
                      stroke-width="1.7"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                </a>
              </div>
              <p class="proj__cat">{p.cat}</p>

              <div class="proj__repo">
                <svg viewBox="0 0 24 24" fill="currentColor" width="13" height="13">
                  <path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.3.8-.6v-2c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z" />
                </svg>
                {p.repo}
              </div>

              <div class="proj__foot">
                <div class="proj__tags">
                  {p.tags.map((t) => (
                    <span class="tag">{t}</span>
                  ))}
                </div>
                <div class="proj__score" title="Lighthouse performance">
                  <b>{p.score}</b> Lighthouse · {p.speed}
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </div>

    <div class="work__cta" data-reveal>
      <a class="btn btn--ghost" href="#contact">
        View the full portfolio
        <span class="btn__arrow">
          <svg viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path
              d="M4 12L12 4M12 4H6M12 4V10"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </span>
      </a>
    </div>
  </div>
</section>

<style>
  .work__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-bottom: clamp(2.5rem, 5vw, 3.5rem);
  }

  .work__title {
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    margin-top: 1rem;
  }
  .work__title .serif-italic {
    color: var(--forest);
  }

  /* pipeline */
  .pipeline {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.65rem 0.95rem;
    background: var(--paper-raised);
    border: 1px solid var(--hairline);
    border-radius: var(--r-pill);
    box-shadow: var(--shadow-card);
  }
  .pipeline__node {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    font-weight: 540;
    color: var(--ink-2);
  }
  .pipeline__node--live {
    color: var(--forest);
    font-weight: 600;
  }
  .pipeline__line {
    width: 1.5rem;
    height: 1px;
    background: var(--line-strong);
    position: relative;
    overflow: hidden;
  }
  .pipeline__line::after {
    content: "";
    position: absolute;
    inset: 0;
    width: 40%;
    background: var(--forest);
    animation: flow 2.4s var(--ease) infinite;
  }
  @keyframes flow {
    from {
      transform: translateX(-100%);
    }
    to {
      transform: translateX(350%);
    }
  }
  .pipeline__build {
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 50%;
    border: 2px solid var(--gold-deep);
    border-top-color: transparent;
    animation: spin 1s linear infinite;
  }
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  /* grid */
  .work__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .proj {
    border-radius: var(--r-lg);
    background: var(--paper-raised);
    border: 1px solid var(--hairline);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    transition: transform 0.5s var(--ease), box-shadow 0.5s var(--ease);
  }
  .proj:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-float);
  }

  .proj__preview {
    position: relative;
    margin: 0.6rem 0.6rem 0;
    border-radius: var(--r-md);
    overflow: hidden;
    aspect-ratio: 16 / 10;
    background: var(--paper-sunk);
    border: 1px solid var(--hairline);
  }

  .proj__chrome {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.5rem 0.7rem;
    background: color-mix(in srgb, var(--ink) 5%, transparent);
  }
  .proj__dots {
    display: flex;
    gap: 0.25rem;
  }
  .proj__dots i {
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 50%;
    background: var(--line-strong);
  }
  .proj__addr {
    font-size: 0.62rem;
    color: var(--muted);
    letter-spacing: -0.01em;
  }

  .proj__screen {
    position: absolute;
    inset: 1.85rem 0 0;
    padding: 0.7rem;
  }

  .proj__deploy {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.62rem;
    font-weight: 600;
    color: var(--on-forest);
    background: color-mix(in srgb, var(--forest-deep) 86%, transparent);
    backdrop-filter: blur(4px);
    padding: 0.3em 0.6em;
    border-radius: var(--r-pill);
  }

  /* ---- mocks ---- */
  /* commerce */
  .t-commerce {
    background: linear-gradient(180deg, #f4eee2, #ece2d0);
  }
  .m-commerce {
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .m-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .m-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.6rem;
    font-weight: 700;
    color: var(--forest);
  }
  .m-cart {
    width: 1.2rem;
    height: 0.55rem;
    border-radius: var(--r-pill);
    background: var(--forest);
  }
  .m-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.35rem;
    flex: 1;
  }
  .m-grid span {
    border-radius: 0.4rem;
    background: #fff;
    border: 1px solid rgba(22, 20, 13, 0.08);
  }
  .m-grid span:nth-child(2) {
    background: var(--forest);
  }
  .m-grid span:nth-child(5) {
    background: var(--gold);
  }

  /* ai */
  .t-ai {
    background: linear-gradient(160deg, #14271d, #0c1a13);
  }
  .m-ai {
    height: 100%;
    display: flex;
    gap: 0.45rem;
  }
  .m-side {
    width: 22%;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .m-side span {
    height: 0.5rem;
    border-radius: var(--r-pill);
    background: rgba(237, 231, 216, 0.16);
  }
  .m-side span:first-child {
    background: var(--gold);
    width: 80%;
  }
  .m-chat {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    justify-content: flex-end;
  }
  .m-msg {
    height: 0.85rem;
    border-radius: 0.5rem;
  }
  .m-msg--in {
    width: 70%;
    background: rgba(237, 231, 216, 0.14);
  }
  .m-msg--out {
    width: 55%;
    align-self: flex-end;
    background: var(--gold);
  }
  .m-msg--sm {
    width: 45%;
  }
  .m-prompt {
    height: 1.1rem;
    border-radius: var(--r-pill);
    background: rgba(237, 231, 216, 0.1);
    border: 1px solid rgba(237, 231, 216, 0.16);
    margin-top: 0.2rem;
  }

  /* studio */
  .t-studio {
    background: linear-gradient(180deg, #f6f1e7, #efe7d8);
  }
  .m-studio {
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  .m-eyebrow {
    width: 2.5rem;
    height: 0.4rem;
    border-radius: var(--r-pill);
    background: var(--gold-deep);
  }
  .m-headline {
    font-family: var(--font-display);
    font-size: 1.15rem;
    line-height: 1.02;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin: 0.4rem 0 auto;
  }
  .m-thumbs {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.35rem;
  }
  .m-thumbs span {
    height: 1.4rem;
    border-radius: 0.4rem;
    background: #fff;
    border: 1px solid rgba(22, 20, 13, 0.08);
  }
  .m-thumbs span:nth-child(2) {
    background: var(--forest);
  }

  /* analytics */
  .t-analytics {
    background: linear-gradient(180deg, #f3eee3, #e9e0d0);
  }
  .m-analytics {
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .m-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.35rem;
  }
  .m-stats span {
    height: 1.1rem;
    border-radius: 0.4rem;
    background: #fff;
    border: 1px solid rgba(22, 20, 13, 0.08);
  }
  .m-stats span:first-child {
    background: var(--forest);
  }
  .m-chart {
    flex: 1;
    display: flex;
    align-items: flex-end;
    gap: 0.3rem;
    padding-top: 0.2rem;
  }
  .m-chart i {
    flex: 1;
    border-radius: 0.25rem 0.25rem 0 0;
    background: var(--forest-soft);
  }
  .m-chart i:nth-child(4) {
    background: var(--gold);
  }
  .m-chart i:last-child {
    background: var(--forest);
  }

  /* ---- meta ---- */
  .proj__meta {
    padding: 1.25rem 1.4rem 1.5rem;
  }
  .proj__line {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }
  .proj__name {
    font-size: 1.3rem;
    letter-spacing: -0.03em;
  }
  .proj__visit {
    display: grid;
    place-items: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 50%;
    border: 1px solid var(--line);
    color: var(--ink);
    flex-shrink: 0;
    transition: background 0.4s var(--ease), color 0.4s var(--ease),
      transform 0.4s var(--ease);
  }
  .proj__visit:hover {
    background: var(--forest);
    color: var(--on-forest);
    transform: rotate(45deg);
  }
  .proj__cat {
    font-size: 0.85rem;
    color: var(--muted);
    margin-top: 0.2rem;
  }
  .proj__repo {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.9rem;
    font-size: 0.8rem;
    font-family: var(--font-sans);
    color: var(--ink-2);
    background: var(--paper-sunk);
    padding: 0.35rem 0.7rem;
    border-radius: var(--r-pill);
    border: 1px solid var(--hairline);
  }
  .proj__foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1rem;
    flex-wrap: wrap;
  }
  .proj__tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .proj__score {
    font-size: 0.76rem;
    color: var(--muted);
    white-space: nowrap;
  }
  .proj__score b {
    color: var(--forest);
    font-weight: 700;
  }

  .work__cta {
    display: flex;
    justify-content: center;
    margin-top: 2.75rem;
  }

  @media (max-width: 760px) {
    .work__grid {
      grid-template-columns: 1fr;
    }
    .work__head {
      align-items: flex-start;
    }
  }
</style>
