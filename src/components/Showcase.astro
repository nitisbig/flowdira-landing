---
import BrandMark from "./BrandMark.astro";

// Real, shipped work — fetched from GitHub + live on Vercel & Cloudflare.
const projects = [
  {
    theme: "editor",
    title: "HTML Website Editor",
    cat: "Visual web editor · Design + Build",
    repo: "nitisbig/html-website-editor",
    url: "https://html-website-editor.vercel.app",
    host: "html-website-editor.vercel.app",
    platform: "vercel",
    tags: ["React", "TypeScript", "Vite"],
  },
  {
    theme: "ai",
    title: "URL2Design",
    cat: "AI design from any URL · Build + AI",
    repo: "nitisbig/url2design",
    url: "https://url2design.niteshghimire223.workers.dev/",
    host: "url2design.niteshghimire223.workers.dev",
    platform: "cloudflare",
    tags: ["Next.js", "AI", "Workers"],
  },
  {
    theme: "commerce",
    title: "Gracias Carpentry",
    cat: "Business website · Design + Build",
    repo: "nitisbig/gracias-capentry",
    url: "https://gracias-capentry.vercel.app",
    host: "gracias-capentry.vercel.app",
    platform: "vercel",
    tags: ["Astro", "Responsive", "SEO"],
  },
  {
    theme: "api",
    title: "Email Verifier",
    cat: "Email verification API · Build",
    repo: "nitisbig/email-verifier-freetiercloudflare",
    url: "https://email-verifier.niteshghimire223.workers.dev/",
    host: "email-verifier.niteshghimire223.workers.dev",
    platform: "cloudflare",
    tags: ["Workers", "TypeScript", "API"],
  },
  {
    theme: "studio",
    title: "Takeaway",
    cat: "Minimal notes app · Build + AI",
    repo: "nitisbig/takeaway",
    url: "https://takeaway-weld.vercel.app",
    host: "takeaway-weld.vercel.app",
    platform: "vercel",
    tags: ["SvelteKit", "Supabase", "Vercel"],
  },
  {
    theme: "analytics",
    title: "Trading Journal",
    cat: "Product landing page · Design + Build",
    repo: "nitisbig/trading-journal-landing",
    url: "https://0d0d6a8d.trading-journal-landing.pages.dev/",
    host: "trading-journal-landing.pages.dev",
    platform: "cloudflare",
    tags: ["Astro", "Pages", "Tailwind"],
  },
];

const platformLabel = { vercel: "Vercel", cloudflare: "Cloudflare" };
// bento rhythm — these indices render as full-width feature cards
const featureIndices = new Set([0, 3]);
---

<section class="work section" id="work">
  <div class="container">
    <header class="work__head">
      <div data-reveal="left">
        <p class="eyebrow">Selected work</p>
        <h2 class="work__title">
          Designed, built &amp; <span class="serif-italic">deployed.</span>
        </h2>
      </div>

      <!-- GitHub → build → live pipeline -->
      <div class="pipeline" data-reveal="right">
        <span class="pipeline__node">
          <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
            <path
              d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.3.8-.6v-2c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z"
            ></path>
          </svg>
          Push
        </span>
        <span class="pipeline__line"></span>
        <span class="pipeline__node">
          <span class="pipeline__build"></span>
          Build
        </span>
        <span class="pipeline__line"></span>
        <span class="pipeline__node pipeline__node--live">
          <svg viewBox="0 0 24 24" fill="currentColor" width="13" height="13">
            <path d="M12 3 22 20H2L12 3Z"></path>
          </svg>
          Live in production
        </span>
      </div>
    </header>

    <div class="work__grid">
      {
        projects.map((p, i) => (
          <article
            class:list={["proj", { "proj--feature": featureIndices.has(i) }]}
            data-reveal="scale"
            data-tilt
            style={`--reveal-delay: ${(i % 2) * 90}ms`}
          >
            <div class="proj__inner">
              <span class="proj__spot" aria-hidden="true" />

              <div class:list={["proj__preview", `t-${p.theme}`]}>
                <div class="proj__chrome">
                  <span class="proj__dots">
                    <i /><i /><i />
                  </span>
                  <span class="proj__addr">{p.host}</span>
                </div>

                <div class="proj__screen">
                  {p.theme === "editor" && (
                    <div class="m-editor">
                      <div class="m-toolbar">
                        <span /><span /><span /><i />
                      </div>
                      <div class="m-canvas">
                        <span class="m-line m-line--lg" />
                        <span class="m-line" />
                        <span class="m-sel">
                          <span class="m-line m-line--sm" />
                        </span>
                      </div>
                    </div>
                  )}
                  {p.theme === "ai" && (
                    <div class="m-ai">
                      <div class="m-side">
                        <span /><span /><span />
                      </div>
                      <div class="m-chat">
                        <span class="m-msg m-msg--in" />
                        <span class="m-msg m-msg--out" />
                        <span class="m-msg m-msg--in m-msg--sm" />
                        <span class="m-prompt" />
                      </div>
                    </div>
                  )}
                  {p.theme === "commerce" && (
                    <div class="m-commerce">
                      <div class="m-bar">
                        <span class="m-brand">
                          <BrandMark size={10} /> Gracias
                        </span>
                        <span class="m-cart" />
                      </div>
                      <div class="m-grid">
                        <span /><span /><span /><span /><span /><span />
                      </div>
                    </div>
                  )}
                  {p.theme === "api" && (
                    <div class="m-api">
                      <div class="m-req">
                        <span class="m-method">POST</span>
                        <span class="m-path" />
                      </div>
                      <div class="m-res">
                        <span class="m-json" />
                        <span class="m-json m-json--sm" />
                        <span class="m-valid">
                          <svg viewBox="0 0 16 16" fill="none" width="9" height="9">
                            <path
                              d="M3 8.5 6.5 12 13 4.5"
                              stroke="currentColor"
                              stroke-width="2.2"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                            />
                          </svg>
                          deliverable
                        </span>
                      </div>
                    </div>
                  )}
                  {p.theme === "studio" && (
                    <div class="m-studio">
                      <span class="m-eyebrow" />
                      <p class="m-headline">One lesson<br />worth keeping</p>
                      <div class="m-thumbs">
                        <span /><span /><span />
                      </div>
                    </div>
                  )}
                  {p.theme === "analytics" && (
                    <div class="m-analytics">
                      <div class="m-stats">
                        <span /><span /><span />
                      </div>
                      <div class="m-chart">
                        <i style="height:40%" /><i style="height:70%" />
                        <i style="height:55%" /><i style="height:90%" />
                        <i style="height:65%" /><i style="height:100%" />
                      </div>
                    </div>
                  )}
                </div>

                <span class:list={["proj__deploy", `proj__deploy--${p.platform}`]}>
                  {p.platform === "cloudflare" ? (
                    <svg viewBox="0 0 24 24" fill="currentColor" width="12" height="12">
                      <path d="M7 18h10a4 4 0 0 0 .5-7.97A6 6 0 0 0 6 9.5 3.5 3.5 0 0 0 7 18Z" />
                    </svg>
                  ) : (
                    <svg viewBox="0 0 24 24" fill="currentColor" width="10" height="10">
                      <path d="M12 3 22 20H2L12 3Z" />
                    </svg>
                  )}
                  Live
                </span>
              </div>

              <div class="proj__meta">
                <div class="proj__line">
                  <h3 class="proj__name">{p.title}</h3>
                  <a
                    class="proj__visit"
                    href={p.url}
                    target="_blank"
                    rel="noopener"
                    aria-label={`Visit ${p.title}`}
                  >
                    <svg viewBox="0 0 16 16" fill="none" width="14" height="14">
                      <path
                        d="M4 12L12 4M12 4H6M12 4V10"
                        stroke="currentColor"
                        stroke-width="1.7"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </a>
                </div>
                <p class="proj__cat">{p.cat}</p>

                <a
                  class="proj__repo"
                  href={`https://github.com/${p.repo}`}
                  target="_blank"
                  rel="noopener"
                >
                  <svg viewBox="0 0 24 24" fill="currentColor" width="13" height="13">
                    <path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.3.8-.6v-2c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z" />
                  </svg>
                  <span class="proj__repo-name">{p.repo}</span>
                </a>

                <div class="proj__foot">
                  <div class="proj__tags">
                    {p.tags.map((t) => (
                      <span class="tag">{t}</span>
                    ))}
                  </div>
                  <span
                    class:list={["proj__plat", `proj__plat--${p.platform}`]}
                    title={`Deployed on ${platformLabel[p.platform]}`}
                  >
                    {p.platform === "cloudflare" ? (
                      <svg viewBox="0 0 24 24" fill="currentColor" width="12" height="12">
                        <path d="M7 18h10a4 4 0 0 0 .5-7.97A6 6 0 0 0 6 9.5 3.5 3.5 0 0 0 7 18Z" />
                      </svg>
                    ) : (
                      <svg viewBox="0 0 24 24" fill="currentColor" width="11" height="11">
                        <path d="M12 3 22 20H2L12 3Z" />
                      </svg>
                    )}
                    {platformLabel[p.platform]}
                  </span>
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </div>

    <div class="work__cta" data-reveal>
      <a
        class="btn btn--ghost"
        href="https://github.com/nitisbig"
        target="_blank"
        rel="noopener"
      >
        Browse more on GitHub
        <span class="btn__arrow">
          <svg viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path
              d="M4 12L12 4M12 4H6M12 4V10"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </span>
      </a>
    </div>
  </div>
</section>

<style>
  .work__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-bottom: clamp(2.5rem, 5vw, 3.5rem);
  }

  .work__title {
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    margin-top: 1rem;
  }
  .work__title .serif-italic {
    color: var(--blue);
  }

  /* pipeline */
  .pipeline {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.65rem 0.95rem;
    background: var(--paper-raised);
    border: 1px solid var(--hairline);
    border-radius: var(--r-pill);
    box-shadow: var(--shadow-card);
  }
  .pipeline__node {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    font-weight: 540;
    color: var(--ink-2);
  }
  .pipeline__node--live {
    color: var(--blue);
    font-weight: 600;
  }
  .pipeline__line {
    width: 1.5rem;
    height: 1px;
    background: var(--line-strong);
    position: relative;
    overflow: hidden;
  }
  .pipeline__line::after {
    content: "";
    position: absolute;
    inset: 0;
    width: 40%;
    background: var(--blue);
    animation: flow 2.4s var(--ease) infinite;
  }
  @keyframes flow {
    from {
      transform: translateX(-100%);
    }
    to {
      transform: translateX(350%);
    }
  }
  .pipeline__build {
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 50%;
    border: 2px solid var(--blue);
    border-top-color: transparent;
    animation: spin 1s linear infinite;
  }
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  /* grid */
  .work__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .proj {
    border-radius: var(--r-lg);
    perspective: 1100px;
  }
  .proj--feature {
    grid-column: 1 / -1;
  }

  /* tilt + lift target */
  .proj__inner {
    position: relative;
    height: 100%;
    border-radius: var(--r-lg);
    background: var(--paper-raised);
    border: 1px solid var(--hairline);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    transform: perspective(1100px) rotateX(var(--rx, 0deg)) rotateY(var(--ry, 0deg));
    transform-style: preserve-3d;
    transition: transform 0.5s var(--ease), box-shadow 0.5s var(--ease),
      border-color 0.5s var(--ease);
  }
  .proj:hover .proj__inner {
    box-shadow: var(--shadow-float), var(--blue-glow);
    border-color: var(--blue-line);
  }

  /* feature cards lay preview + meta side by side */
  .proj--feature .proj__inner {
    display: grid;
    grid-template-columns: 1.08fr 0.92fr;
    align-items: stretch;
  }

  /* pointer-tracking spotlight */
  .proj__spot {
    position: absolute;
    inset: 0;
    z-index: 5;
    pointer-events: none;
    opacity: 0;
    background: radial-gradient(
      460px circle at var(--mx, 50%) var(--my, 50%),
      rgba(10, 114, 247, 0.16),
      transparent 60%
    );
    transition: opacity 0.4s var(--ease);
  }
  .proj:hover .proj__spot {
    opacity: 1;
  }

  .proj__preview {
    position: relative;
    margin: 0.6rem 0.6rem 0;
    border-radius: var(--r-md);
    overflow: hidden;
    aspect-ratio: 16 / 10;
    background: var(--paper-sunk);
    border: 1px solid var(--hairline);
  }
  .proj--feature .proj__preview {
    aspect-ratio: auto;
    margin: 0.7rem 0 0.7rem 0.7rem;
    min-height: 17rem;
  }

  .proj__chrome {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.5rem 0.7rem;
    background: color-mix(in srgb, var(--ink) 5%, transparent);
  }
  .proj__dots {
    display: flex;
    gap: 0.25rem;
  }
  .proj__dots i {
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 50%;
    background: var(--line-strong);
  }
  .proj__addr {
    font-size: 0.62rem;
    color: var(--muted);
    letter-spacing: -0.01em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .proj__screen {
    position: absolute;
    inset: 1.85rem 0 0;
    padding: 0.7rem;
  }

  .proj__deploy {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.62rem;
    font-weight: 600;
    color: #fff;
    background: color-mix(in srgb, var(--blue-deep) 86%, transparent);
    backdrop-filter: blur(4px);
    padding: 0.3em 0.6em;
    border-radius: var(--r-pill);
  }
  .proj__deploy--cloudflare {
    color: #4a2e05;
    background: color-mix(in srgb, var(--gold) 90%, transparent);
  }

  /* ---- mocks ---- */
  /* editor */
  .t-editor {
    background: linear-gradient(180deg, #f5f0e6, #ece2d0);
  }
  .m-editor {
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .m-toolbar {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.3rem 0.4rem;
    border-radius: var(--r-pill);
    background: var(--forest);
    align-self: flex-start;
  }
  .m-toolbar span {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 0.2rem;
    background: rgba(237, 231, 216, 0.55);
  }
  .m-toolbar i {
    width: 0.7rem;
    height: 0.5rem;
    border-radius: 0.2rem;
    background: var(--blue-bright);
  }
  .m-canvas {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 0.55rem;
    border-radius: 0.5rem;
    background: #fff;
    border: 1px solid rgba(22, 20, 13, 0.08);
  }
  .m-line {
    height: 0.5rem;
    border-radius: var(--r-pill);
    background: var(--paper-sunk);
    width: 90%;
  }
  .m-line--lg {
    height: 0.85rem;
    width: 65%;
    background: var(--forest);
  }
  .m-line--sm {
    width: 55%;
    margin: 0;
  }
  .m-sel {
    padding: 0.3rem;
    border-radius: 0.35rem;
    border: 1.5px dashed var(--blue);
    position: relative;
  }
  .m-sel::after {
    content: "";
    position: absolute;
    right: -3px;
    bottom: -3px;
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 50%;
    background: var(--blue);
  }

  /* ai */
  .t-ai {
    background: linear-gradient(160deg, #0a1f4a, #051028);
  }
  .m-ai {
    height: 100%;
    display: flex;
    gap: 0.45rem;
  }
  .m-side {
    width: 22%;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .m-side span {
    height: 0.5rem;
    border-radius: var(--r-pill);
    background: rgba(237, 231, 216, 0.16);
  }
  .m-side span:first-child {
    background: var(--blue-bright);
    width: 80%;
  }
  .m-chat {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    justify-content: flex-end;
  }
  .m-msg {
    height: 0.85rem;
    border-radius: 0.5rem;
  }
  .m-msg--in {
    width: 70%;
    background: rgba(237, 231, 216, 0.14);
  }
  .m-msg--out {
    width: 55%;
    align-self: flex-end;
    background: var(--blue);
  }
  .m-msg--sm {
    width: 45%;
  }
  .m-prompt {
    height: 1.1rem;
    border-radius: var(--r-pill);
    background: rgba(237, 231, 216, 0.1);
    border: 1px solid rgba(237, 231, 216, 0.16);
    margin-top: 0.2rem;
  }

  /* commerce */
  .t-commerce {
    background: linear-gradient(180deg, #f4eee2, #ece2d0);
  }
  .m-commerce {
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .m-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .m-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.6rem;
    font-weight: 700;
    color: var(--forest);
  }
  .m-cart {
    width: 1.2rem;
    height: 0.55rem;
    border-radius: var(--r-pill);
    background: var(--forest);
  }
  .m-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.35rem;
    flex: 1;
  }
  .m-grid span {
    border-radius: 0.4rem;
    background: #fff;
    border: 1px solid rgba(22, 20, 13, 0.08);
  }
  .m-grid span:nth-child(2) {
    background: var(--forest);
  }
  .m-grid span:nth-child(5) {
    background: var(--gold);
  }

  /* api */
  .t-api {
    background: linear-gradient(160deg, #0a1f4a, #051028);
  }
  .m-api {
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    justify-content: center;
  }
  .m-req {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }
  .m-method {
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: #fff;
    background: var(--blue);
    padding: 0.18em 0.45em;
    border-radius: 0.3rem;
  }
  .m-path {
    flex: 1;
    height: 0.55rem;
    border-radius: var(--r-pill);
    background: rgba(237, 231, 216, 0.16);
  }
  .m-res {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.55rem;
    border-radius: 0.5rem;
    background: rgba(237, 231, 216, 0.06);
    border: 1px solid rgba(237, 231, 216, 0.12);
  }
  .m-json {
    height: 0.45rem;
    width: 80%;
    border-radius: var(--r-pill);
    background: rgba(237, 231, 216, 0.18);
  }
  .m-json--sm {
    width: 55%;
  }
  .m-valid {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    margin-top: 0.1rem;
    font-size: 0.55rem;
    font-weight: 600;
