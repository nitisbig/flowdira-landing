---
// Real, shipped work — live on Vercel, previewed with actual screenshots.
const projects = [
  {
    img: "/work/portfolio.webp",
    title: "Nitesh — Portfolio",
    cat: "Personal developer portfolio · Design + Build",
    repo: "nitisbig/portfolio-site",
    url: "https://portfolio-site-three-coral.vercel.app/",
    host: "portfolio-site-three-coral.vercel.app",
    platform: "vercel",
    tags: ["Astro", "Tailwind", "Editorial"],
  },
  {
    img: "/work/maintenance.webp",
    title: "The Maintenance Man",
    cat: "Home-services business site · Design + Build",
    repo: null,
    url: "https://themaintenanceman.vercel.app/",
    host: "themaintenanceman.vercel.app",
    platform: "vercel",
    tags: ["Responsive", "SEO", "Local business"],
  },
  {
    img: "/work/appointment.webp",
    title: "BrightSmile Dental",
    cat: "Dental booking experience · Design + Build",
    repo: "nitisbig/appointment-system",
    url: "https://appointment-system-vert-five.vercel.app/",
    host: "appointment-system-vert-five.vercel.app",
    platform: "vercel",
    tags: ["Next.js", "TypeScript", "Booking"],
  },
  {
    img: "/work/takeaway.webp",
    title: "Takeaways",
    cat: "Minimal notes app · Design + Build",
    repo: "nitisbig/takeaway",
    url: "https://takeaway-weld.vercel.app/",
    host: "takeaway-weld.vercel.app",
    platform: "vercel",
    tags: ["SvelteKit", "Supabase", "Vercel"],
  },
  {
    img: "/work/claude-guide.webp",
    title: "Claude Code Guide",
    cat: "Interactive learning app · Design + Build",
    repo: "nitisbig/claude-code-guide",
    url: "https://claude-code-guide-eosin-delta.vercel.app/",
    host: "claude-code-guide-eosin-delta.vercel.app",
    platform: "vercel",
    tags: ["Next.js", "TypeScript", "Education"],
  },
  {
    img: "/work/explorative.webp",
    title: "Explorative Giants",
    cat: "Philosophy reference · Design + Build",
    repo: "nitisbig/explorative-giants",
    url: "https://explorative-giants.vercel.app/",
    host: "explorative-giants.vercel.app",
    platform: "vercel",
    tags: ["Next.js", "TypeScript", "Tailwind"],
  },
  {
    img: "/work/interstellar.webp",
    title: "Interstellar — Gargantua",
    cat: "Audio-reactive WebGL visualizer · Build + Motion",
    repo: "nitisbig/interstellar",
    url: "https://interstellar-phi-eosin.vercel.app/",
    host: "interstellar-phi-eosin.vercel.app",
    platform: "vercel",
    tags: ["Canvas", "WebGL", "Audio-reactive"],
  },
];

const platformLabel = { vercel: "Vercel", cloudflare: "Cloudflare" };
// bento rhythm — these indices render as full-width feature cards
const featureIndices = new Set([0, 3, 6]);
---

<section class="work section" id="work">
  <div class="container">
    <header class="work__head">
      <div data-reveal="left">
        <p class="eyebrow">Selected work</p>
        <h2 class="work__title">
          Designed, built &amp; <span class="serif-italic">deployed.</span>
        </h2>
      </div>

      <!-- GitHub → build → live pipeline -->
      <div class="pipeline" data-reveal="right">
        <span class="pipeline__node">
          <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
            <path
              d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.3.8-.6v-2c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z"
            ></path>
          </svg>
          Push
        </span>
        <span class="pipeline__line"></span>
        <span class="pipeline__node">
          <span class="pipeline__build"></span>
          Build
        </span>
        <span class="pipeline__line"></span>
        <span class="pipeline__node pipeline__node--live">
          <svg viewBox="0 0 24 24" fill="currentColor" width="13" height="13">
            <path d="M12 3 22 20H2L12 3Z"></path>
          </svg>
          Live in production
        </span>
      </div>
    </header>

    <div class="work__grid">
      {
        projects.map((p, i) => (
          <article
            class:list={["proj", { "proj--feature": featureIndices.has(i) }]}
            data-reveal="scale"
            data-tilt
            style={`--reveal-delay: ${(i % 2) * 90}ms`}
          >
            <div class="proj__inner">
              <span class="proj__spot" aria-hidden="true" />

              <a
                class="proj__preview"
                href={p.url}
                target="_blank"
                rel="noopener"
                aria-label={`Open ${p.title} live`}
              >
                <div class="proj__chrome">
                  <span class="proj__dots">
                    <i /><i /><i />
                  </span>
                  <span class="proj__addr">{p.host}</span>
                </div>

                <div class="proj__shot-wrap">
                  <img
                    class="proj__shot"
                    src={p.img}
                    alt={`${p.title} — live site preview`}
                    width="1280"
                    height="800"
                    loading="lazy"
                    decoding="async"
                  />
                </div>

                <span class:list={["proj__deploy", `proj__deploy--${p.platform}`]}>
                  {p.platform === "cloudflare" ? (
                    <svg viewBox="0 0 24 24" fill="currentColor" width="12" height="12">
                      <path d="M7 18h10a4 4 0 0 0 .5-7.97A6 6 0 0 0 6 9.5 3.5 3.5 0 0 0 7 18Z" />
                    </svg>
                  ) : (
                    <svg viewBox="0 0 24 24" fill="currentColor" width="10" height="10">
                      <path d="M12 3 22 20H2L12 3Z" />
                    </svg>
                  )}
                  Live
                </span>
              </a>

              <div class="proj__meta">
                <div class="proj__line">
                  <h3 class="proj__name">{p.title}</h3>
                  <a
                    class="proj__visit"
                    href={p.url}
                    target="_blank"
                    rel="noopener"
                    aria-label={`Visit ${p.title}`}
                  >
                    <svg viewBox="0 0 16 16" fill="none" width="14" height="14">
                      <path
                        d="M4 12L12 4M12 4H6M12 4V10"
                        stroke="currentColor"
                        stroke-width="1.7"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </a>
                </div>
                <p class="proj__cat">{p.cat}</p>

                {p.repo && (
                  <a
                    class="proj__repo"
                    href={`https://github.com/${p.repo}`}
                    target="_blank"
                    rel="noopener"
                  >
                    <svg viewBox="0 0 24 24" fill="currentColor" width="13" height="13">
                      <path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.3.8-.6v-2c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z" />
                    </svg>
                    <span class="proj__repo-name">{p.repo}</span>
                  </a>
                )}

                <div class="proj__foot">
                  <div class="proj__tags">
                    {p.tags.map((t) => (
                      <span class="tag">{t}</span>
                    ))}
                  </div>
                  <span
                    class:list={["proj__plat", `proj__plat--${p.platform}`]}
                    title={`Deployed on ${platformLabel[p.platform]}`}
                  >
                    {p.platform === "cloudflare" ? (
                      <svg viewBox="0 0 24 24" fill="currentColor" width="12" height="12">
                        <path d="M7 18h10a4 4 0 0 0 .5-7.97A6 6 0 0 0 6 9.5 3.5 3.5 0 0 0 7 18Z" />
                      </svg>
                    ) : (
                      <svg viewBox="0 0 24 24" fill="currentColor" width="11" height="11">
                        <path d="M12 3 22 20H2L12 3Z" />
                      </svg>
                    )}
                    {platformLabel[p.platform]}
                  </span>
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </div>

    <div class="work__cta" data-reveal>
      <a
        class="btn btn--ghost"
        href="https://github.com/nitisbig"
        target="_blank"
        rel="noopener"
      >
        Browse more on GitHub
        <span class="btn__arrow">
          <svg viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path
              d="M4 12L12 4M12 4H6M12 4V10"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </span>
      </a>
    </div>
  </div>
</section>

<style>
  .work__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-bottom: clamp(2.5rem, 5vw, 3.5rem);
  }

  .work__title {
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    margin-top: 1rem;
  }
  .work__title .serif-italic {
    color: var(--blue);
  }

  /* pipeline */
  .pipeline {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.65rem 0.95rem;
    background: var(--paper-raised);
    border: 1px solid var(--hairline);
    border-radius: var(--r-pill);
    box-shadow: var(--shadow-card);
  }
  .pipeline__node {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    font-weight: 540;
    color: var(--ink-2);
  }
  .pipeline__node--live {
    color: var(--blue);
    font-weight: 600;
  }
  .pipeline__line {
    width: 1.5rem;
    height: 1px;
    background: var(--line-strong);
    position: relative;
    overflow: hidden;
  }
  .pipeline__line::after {
    content: "";
    position: absolute;
    inset: 0;
    width: 40%;
    background: var(--blue);
    animation: flow 2.4s var(--ease) infinite;
  }
  @keyframes flow {
    from {
      transform: translateX(-100%);
    }
    to {
      transform: translateX(350%);
    }
  }
  .pipeline__build {
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 50%;
    border: 2px solid var(--blue);
    border-top-color: transparent;
    animation: spin 1s linear infinite;
  }
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  /* grid */
  .work__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .proj {
    border-radius: var(--r-lg);
    perspective: 1100px;
  }
  .proj--feature {
    grid-column: 1 / -1;
  }

  /* tilt + lift target */
  .proj__inner {
    position: relative;
    height: 100%;
    border-radius: var(--r-lg);
    background: var(--paper-raised);
    border: 1px solid var(--hairline);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    transform: perspective(1100px) rotateX(var(--rx, 0deg)) rotateY(var(--ry, 0deg));
    transform-style: preserve-3d;
    transition: transform 0.5s var(--ease), box-shadow 0.5s var(--ease),
      border-color 0.5s var(--ease);
  }
  .proj:hover .proj__inner {
    box-shadow: var(--shadow-float), var(--blue-glow);
    border-color: var(--blue-line);
  }

  /* feature cards lay preview + meta side by side */
  .proj--feature .proj__inner {
    display: grid;
    grid-template-columns: 1.08fr 0.92fr;
    align-items: stretch;
  }

  /* pointer-tracking spotlight */
  .proj__spot {
    position: absolute;
    inset: 0;
    z-index: 5;
    pointer-events: none;
    opacity: 0;
    background: radial-gradient(
      460px circle at var(--mx, 50%) var(--my, 50%),
      rgba(10, 114, 247, 0.16),
      transparent 60%
    );
    transition: opacity 0.4s var(--ease);
  }
  .proj:hover .proj__spot {
    opacity: 1;
  }

  .proj__preview {
    position: relative;
    display: flex;
    flex-direction: column;
    margin: 0.6rem 0.6rem 0;
    border-radius: var(--r-md);
    overflow: hidden;
    aspect-ratio: 16 / 10;
    background: var(--paper-sunk);
    border: 1px solid var(--hairline);
    cursor: pointer;
  }
  .proj--feature .proj__preview {
    aspect-ratio: auto;
    margin: 0.7rem 0 0.7rem 0.7rem;
    min-height: 17rem;
  }

  .proj__chrome {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.5rem 0.7rem;
    background: color-mix(in srgb, var(--ink) 5%, transparent);
  }
  .proj__dots {
    display: flex;
    gap: 0.25rem;
  }
  .proj__dots i {
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 50%;
    background: var(--line-strong);
  }
  .proj__addr {
    font-size: 0.62rem;
    color: var(--muted);
    letter-spacing: -0.01em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* real screenshot fills the viewport area below the chrome */
  .proj__shot-wrap {
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }
  .proj__shot {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    transition: transform 0.6s var(--ease);
  }
  .proj:hover .proj__shot {
    transform: scale(1.035);
  }

  .proj__deploy {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.62rem;
    font-weight: 600;
    color: #fff;
    background: color-mix(in srgb, var(--blue-deep) 86%, transparent);
    backdrop-filter: blur(4px);
    padding: 0.3em 0.6em;
    border-radius: var(--r-pill);
  }
  .proj__deploy--cloudflare {
    color: #4a2e05;
    background: color-mix(in srgb, var(--gold) 90%, transparent);
  }

  /* ---- meta ---- */
  .proj__meta {
    padding: 1.25rem 1.4rem 1.5rem;
    display: flex;
    flex-direction: column;
  }
  .proj--feature .proj__meta {
    justify-content: center;
    padding: clamp(1.5rem, 3vw, 2.5rem);
  }
  .proj__line {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }
  .proj__name {
    font-size: 1.3rem;
    letter-spacing: -0.03em;
  }
  .proj--feature .proj__name {
    font-size: clamp(1.5rem, 2.5vw, 2.1rem);
  }
  .proj__visit {
    display: grid;
    place-items: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 50%;
    border: 1px solid var(--line);
    color: var(--ink);
    flex-shrink: 0;
    transition: background 0.4s var(--ease), color 0.4s var(--ease),
      transform 0.4s var(--ease), border-color 0.4s var(--ease);
  }
  .proj__visit:hover {
    background: var(--blue-grad);
    border-color: transparent;
    color: #fff;
    transform: rotate(45deg);
  }
  .proj__cat {
    font-size: 0.85rem;
    color: var(--muted);
    margin-top: 0.2rem;
  }
  .proj--feature .proj__cat {
    font-size: 0.95rem;
  }
  .proj__repo {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.9rem;
    font-size: 0.8rem;
    font-family: var(--font-sans);
    color: var(--ink-2);
    background: var(--paper-sunk);
    padding: 0.35rem 0.7rem;
    border-radius: var(--r-pill);
    border: 1px solid var(--hairline);
    max-width: 100%;
    min-width: 0;
    align-self: flex-start;
    transition: color 0.3s var(--ease), border-color 0.3s var(--ease),
      background 0.3s var(--ease);
  }
  .proj__repo-name {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
  }
  .proj__repo svg {
    flex-shrink: 0;
  }
  .proj__repo:hover {
    color: var(--blue);
    border-color: var(--blue-line);
    background: var(--blue-soft);
  }
  .proj__foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1rem;
    flex-wrap: wrap;
  }
  .proj__tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .proj__plat {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.74rem;
    font-weight: 600;
    color: var(--blue);
    white-space: nowrap;
  }
  .proj__plat--cloudflare {
    color: var(--gold-deep);
  }

  .work__cta {
    display: flex;
    justify-content: center;
    margin-top: 2.75rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .proj__inner {
      transform: none !important;
    }
  }

  @media (max-width: 760px) {
    .work__grid {
      grid-template-columns: 1fr;
    }
    .work__head {
      align-items: flex-start;
    }
    .proj--feature .proj__inner {
      grid-template-columns: 1fr;
    }
    .proj--feature .proj__preview {
      margin: 0.6rem 0.6rem 0;
      min-height: 0;
      aspect-ratio: 16 / 10;
    }
  }
</style>

<script>
  // Premium hover layer: pointer-tracking spotlight + subtle 3D tilt.
  // Skipped entirely for touch / reduced-motion so it never gets in the way.
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const fine = window.matchMedia("(hover: hover) and (pointer: fine)").matches;

  if (!reduce && fine) {
    const cards = document.querySelectorAll<HTMLElement>("[data-tilt]");
    cards.forEach((card) => {
      const inner = card.querySelector<HTMLElement>(".proj__inner");
      const spot = card.querySelector<HTMLElement>(".proj__spot");
      const MAX = 5; // degrees

      const onMove = (e: PointerEvent) => {
        const r = card.getBoundingClientRect();
        const px = (e.clientX - r.left) / r.width;
        const py = (e.clientY - r.top) / r.height;
        if (inner) {
          inner.style.setProperty("--ry", `${(px - 0.5) * MAX * 2}deg`);
          inner.style.setProperty("--rx", `${(0.5 - py) * MAX * 2}deg`);
        }
        if (spot) {
          spot.style.setProperty("--mx", `${px * 100}%`);
          spot.style.setProperty("--my", `${py * 100}%`);
        }
      };
      const reset = () => {
        if (!inner) return;
        inner.style.setProperty("--rx", "0deg");
        inner.style.setProperty("--ry", "0deg");
      };

      card.addEventListener("pointermove", onMove);
      card.addEventListener("pointerleave", reset);
    });
  }
</script>
