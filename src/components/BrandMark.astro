---
/* The Flowdira mark — a four-point sparkle that reads as both
   a bloom and a flow. Inherits color via currentColor. */
interface Props {
  size?: number;
  class?: string;
}
const { size = 24, class: className = "" } = Astro.props;
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  aria-hidden="true"
>
  <path
    d="M12 1.5c.62 5.4 3.6 8.38 9 9-5.4.62-8.38 3.6-9 9-.62-5.4-3.6-8.38-9-9 5.4-.62 8.38-3.6 9-9Z"
    fill="currentColor"></path>
</svg>
