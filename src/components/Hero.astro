---
import BrandMark from "./BrandMark.astro";
---

<section class="hero">
  <div class="container hero__grid">
    <!-- ░░ Left — message ░░ -->
    <div class="hero__copy">
      <p class="eyebrow hero__rise">
        <BrandMark size={13} /> Website design · development · AI
      </p>

      <h1 class="hero__title hero__rise">
        Design-led websites,<br />
        <span class="serif-italic">intelligently</span> built.
      </h1>

      <p class="hero__lede hero__rise">
        Flowdira is a website design &amp; development studio building fast,
        modern web experiences with <strong>AI woven in</strong> — designed in
        Figma, developed clean, and shipped from GitHub to Vercel.
      </p>

      <div class="hero__actions hero__rise">
        <a class="btn" href="#contact">
          Start a project
          <span class="btn__arrow">
            <svg viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path
                d="M4 12L12 4M12 4H6M12 4V10"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </span>
        </a>
        <a class="btn btn--ghost" href="#work"> See the work </a>
      </div>

      <div class="hero__trust hero__rise">
        <div class="avatars" aria-hidden="true">
          <span style="--a:#2c5240;--b:#1f3d2e">AK</span>
          <span style="--a:#c9a86a;--b:#a07f44">MR</span>
          <span style="--a:#3b372d;--b:#16140d">JT</span>
          <span style="--a:#335440;--b:#14271d">SD</span>
        </div>
        <p class="hero__trust-text">
          <strong>40+ founders</strong> shipped &amp; growing — design you'll
          love, guaranteed.
        </p>
      </div>
    </div>

    <!-- ░░ Right — living preview ░░ -->
    <div class="hero__stage hero__rise" aria-hidden="true">
      <div class="sunburst"></div>

      <figure class="preview">
        <div class="preview__bar">
          <span class="dots"><i></i><i></i><i></i></span>
          <span class="preview__url">
            <svg viewBox="0 0 16 16" fill="none" width="11" height="11">
              <path
                d="M5 7V5a3 3 0 1 1 6 0v2m-7 0h8v6H4V7Z"
                stroke="currentColor"
                stroke-width="1.3"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
            flowdira.com
          </span>
          <span class="preview__live"><i></i>Live</span>
        </div>

        <div class="preview__body">
          <div class="mini">
            <div class="mini__nav">
              <span class="mini__logo"><BrandMark size={11} /> Studio</span>
              <span class="mini__pill"></span>
            </div>
            <div class="mini__hero">
              <span class="mini__tag">New · 2026</span>
              <p class="mini__h">Build things<br />people remember.</p>
              <span class="mini__cta">Get started →</span>
            </div>
            <div class="mini__cards">
              <span></span><span></span><span></span>
            </div>
          </div>
        </div>
      </figure>

      <!-- Floating: Vercel deploy -->
      <div class="float float--deploy">
        <div class="float__icon">
          <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14">
            <path d="M12 3 22 20H2L12 3Z"></path>
          </svg>
        </div>
        <div>
          <p class="float__title">Deployed to Vercel</p>
          <p class="float__sub">0.4s load · 100 Lighthouse</p>
        </div>
      </div>

      <!-- Floating: GitHub status -->
      <div class="float float--git">
        <svg viewBox="0 0 24 24" fill="currentColor" width="15" height="15">
          <path
            d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.3.8-.6v-2c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z"
          ></path>
        </svg>
        <span><b>main</b> · passing</span>
        <i class="float__check">
          <svg viewBox="0 0 16 16" fill="none" width="11" height="11">
            <path
              d="M3 8.5 6.5 12 13 4.5"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </i>
      </div>

      <!-- Floating: stat -->
      <div class="float float--stat">
        <span class="float__spark"><BrandMark size={20} /></span>
        <div>
          <p class="float__big">+480</p>
          <p class="float__sub">projects shipped</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: clamp(2.5rem, 5vw, 4.5rem) clamp(3.5rem, 7vw, 6rem);
  }

  .hero__grid {
    display: grid;
    grid-template-columns: 1.04fr 0.96fr;
    align-items: center;
    gap: clamp(2rem, 5vw, 4rem);
  }

  /* ---- copy ---- */
  .hero__title {
    font-size: clamp(2.9rem, 7vw, 5.1rem);
    margin: 1.2rem 0 1.4rem;
    letter-spacing: -0.035em;
  }

  .hero__title .serif-italic {
    color: var(--forest);
  }

  .hero__lede {
    max-width: 30rem;
    font-size: clamp(1.02rem, 1.5vw, 1.18rem);
    color: var(--muted);
    line-height: 1.65;
  }

  .hero__lede strong {
    color: var(--ink-2);
    font-weight: 600;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin: 2rem 0 2.25rem;
  }

  .hero__trust {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }

  .avatars {
    display: flex;
  }

  .avatars span {
    display: grid;
    place-items: center;
    width: 2.1rem;
    height: 2.1rem;
    border-radius: 50%;
    border: 2.5px solid var(--paper);
    margin-left: -0.7rem;
    background: linear-gradient(140deg, var(--a), var(--b));
    box-shadow: var(--shadow-card);
    font-family: var(--font-sans);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--on-forest);
  }

  .avatars span:first-child {
    margin-left: 0;
  }

  .hero__trust-text {
    font-size: 0.88rem;
    color: var(--muted);
    max-width: 17rem;
    line-height: 1.45;
  }

  .hero__trust-text strong {
    color: var(--ink);
    font-weight: 600;
  }

  /* ---- stage ---- */
  .hero__stage {
    position: relative;
    aspect-ratio: 1 / 1.02;
    display: grid;
    place-items: center;
  }

  .sunburst {
    position: absolute;
    inset: -6%;
    border-radius: 50%;
    background: repeating-conic-gradient(
      from 0deg,
      rgba(201, 168, 106, 0.42) 0deg 0.7deg,
      transparent 0.7deg 6deg
    );
    -webkit-mask: radial-gradient(
      circle,
      #000 12%,
      rgba(0, 0, 0, 0.5) 38%,
      transparent 66%
    );
    mask: radial-gradient(
      circle,
      #000 12%,
      rgba(0, 0, 0, 0.5) 38%,
      transparent 66%
    );
    animation: spin 90s linear infinite;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  /* ---- browser preview ---- */
  .preview {
    position: relative;
    width: 86%;
    border-radius: var(--r-lg);
    background: var(--paper-raised);
    border: 1px solid var(--hairline);
    box-shadow: var(--shadow-deep);
    overflow: hidden;
    transform: rotate(-1.2deg);
  }

  .preview__bar {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.7rem 0.85rem;
    border-bottom: 1px solid var(--hairline);
    background: var(--paper);
  }

  .dots {
    display: flex;
    gap: 0.32rem;
  }
  .dots i {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
    background: var(--line-strong);
  }

  .preview__url {
    flex: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    font-size: 0.72rem;
    color: var(--muted);
    background: var(--paper-sunk);
    border-radius: var(--r-pill);
    padding: 0.3rem 0.7rem;
  }

  .preview__live {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--forest);
  }
  .preview__live i {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: #45a06a;
    box-shadow: 0 0 0 3px rgba(69, 160, 106, 0.18);
  }

  .preview__body {
    padding: 0.5rem;
    background: linear-gradient(180deg, var(--paper-raised), var(--paper-sunk));
  }

  /* ---- mini website ---- */
  .mini {
    border-radius: var(--r-md);
    overflow: hidden;
    background: var(--paper-raised);
    border: 1px solid var(--hairline);
  }

  .mini__nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.6rem 0.85rem;
  }
  .mini__logo {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--forest);
  }
  .mini__pill {
    width: 3.5rem;
    height: 0.85rem;
    border-radius: var(--r-pill);
    background: var(--forest);
  }

  .mini__hero {
    text-align: center;
    padding: 1.4rem 1rem 1.6rem;
    background: radial-gradient(
      120% 90% at 50% 0%,
      rgba(31, 61, 46, 0.08),
      transparent 70%
    );
  }
  .mini__tag {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold-deep);
    border: 1px solid var(--line);
    border-radius: var(--r-pill);
    padding: 0.2em 0.7em;
  }
  .mini__h {
    font-family: var(--font-display);
    font-size: 1.35rem;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin: 0.6rem 0 0.8rem;
    color: var(--ink);
  }
  .mini__cta {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--on-forest);
    background: var(--forest);
    padding: 0.5em 1em;
    border-radius: var(--r-pill);
  }

  .mini__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.4rem;
    padding: 0.6rem;
  }
  .mini__cards span {
    height: 2.6rem;
    border-radius: var(--r-sm);
    background: var(--paper-sunk);
    border: 1px solid var(--hairline);
  }
  .mini__cards span:nth-child(2) {
    background: var(--forest);
  }

  /* ---- floating cards ---- */
  .float {
    position: absolute;
    background: var(--paper-raised);
    border: 1px solid var(--hairline);
    border-radius: var(--r-md);
    box-shadow: var(--shadow-float);
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.7rem 0.9rem;
    animation: bob 6s ease-in-out infinite;
  }

  .float__title {
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .float__sub {
    font-size: 0.72rem;
    color: var(--muted);
  }

  .float--deploy {
    top: 4%;
    right: -3%;
    color: var(--on-forest);
    background: var(--forest);
    border-color: var(--forest-line);
  }
  .float--deploy .float__sub {
    color: var(--on-forest-mut);
  }
  .float__icon {
    display: grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.6rem;
    background: rgba(237, 231, 216, 0.14);
    color: var(--on-forest);
  }

  .float--git {
    top: 38%;
    left: -8%;
    font-size: 0.78rem;
    font-weight: 500;
    animation-delay: -2s;
  }
  .float--git b {
    font-weight: 650;
  }
  .float--git svg {
    color: var(--ink);
  }
  .float__check {
    display: grid;
    place-items: center;
    width: 1.2rem;
    height: 1.2rem;
    border-radius: 50%;
    background: var(--forest);
    color: var(--on-forest);
  }

  .float--stat {
    bottom: 3%;
    left: 2%;
    animation-delay: -4s;
  }
  .float__spark {
    display: grid;
    place-items: center;
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 0.8rem;
    background: var(--gold);
    color: var(--forest-deep);
  }
  .float__big {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.03em;
  }

  @keyframes bob {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-9px);
    }
  }

  /* ---- staggered entrance ---- */
  .hero__rise {
    animation: rise 0.9s var(--ease) both;
  }
  .hero__copy .hero__rise:nth-child(1) {
    animation-delay: 0.05s;
  }
  .hero__copy .hero__rise:nth-child(2) {
    animation-delay: 0.14s;
  }
  .hero__copy .hero__rise:nth-child(3) {
    animation-delay: 0.23s;
  }
  .hero__copy .hero__rise:nth-child(4) {
    animation-delay: 0.32s;
  }
  .hero__copy .hero__rise:nth-child(5) {
    animation-delay: 0.41s;
  }
  .hero__stage.hero__rise {
    animation: rise-stage 1.1s var(--ease) 0.2s both;
  }

  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
  }
  @keyframes rise-stage {
    from {
      opacity: 0;
      transform: translateY(26px) scale(0.97);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__rise,
    .float,
    .sunburst {
      animation: none !important;
    }
  }

  /* ---- responsive ---- */
  @media (max-width: 900px) {
    .hero__grid {
      grid-template-columns: 1fr;
      gap: 3.5rem;
    }
    .hero__copy {
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .eyebrow::before {
      display: none;
    }
    .hero__stage {
      max-width: 30rem;
      margin-inline: auto;
      width: 100%;
    }
  }

  @media (max-width: 420px) {
    .float--git {
      left: -2%;
      scale: 0.9;
    }
    .float--deploy {
      right: 0;
      scale: 0.92;
    }
  }
</style>
