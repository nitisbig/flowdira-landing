---
const steps = [
  {
    num: "01",
    title: "Discover",
    desc: "We map your goals, audience and tech stack — then hand you a clear plan with fixed scope and timeline.",
  },
  {
    num: "02",
    title: "Design",
    desc: "Wireframes evolve into polished, on-brand UI in Figma. You review in real time; we refine until it sings.",
  },
  {
    num: "03",
    title: "Develop",
    desc: "Clean Astro & Next.js builds with AI features wired in, type-safe and tested on every single commit.",
  },
  {
    num: "04",
    title: "Deploy",
    desc: "Pushed to GitHub, auto-built and shipped live on Vercel — with analytics, SEO and handover docs.",
  },
];
---

<section class="process section" id="process">
  <div class="container">
    <header class="process__head" data-reveal>
      <p class="eyebrow eyebrow--center">How we work</p>
      <h2 class="process__title">
        First call to first deploy —<br />
        <span class="serif-italic">weeks</span>, not months.
      </h2>
    </header>

    <ol class="process__track">
      {
        steps.map((s, i) => (
          <li class="step" data-reveal style={`--reveal-delay: ${i * 110}ms`}>
            <span class="step__num">{s.num}</span>
            <h3 class="step__title">{s.title}</h3>
            <p class="step__desc">{s.desc}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .process__head {
    text-align: center;
    max-width: 40rem;
    margin: 0 auto clamp(3rem, 6vw, 4.5rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .process__title {
    font-size: clamp(2rem, 4.5vw, 3.2rem);
  }
  .process__title .serif-italic {
    color: var(--forest);
  }

  .process__track {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    border-top: 1px solid var(--line);
    padding-top: 2.5rem;
    position: relative;
  }

  .step {
    position: relative;
  }

  .step__num {
    position: absolute;
    top: -3.4rem;
    left: 0;
    display: grid;
    place-items: center;
    width: 2.9rem;
    height: 2.9rem;
    border-radius: 50%;
    background: var(--paper);
    border: 1px solid var(--line);
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--forest);
    transition: background 0.4s var(--ease), color 0.4s var(--ease),
      border-color 0.4s var(--ease);
  }

  .step:hover .step__num {
    background: var(--forest);
    color: var(--gold);
    border-color: var(--forest);
  }

  .step__title {
    font-size: 1.45rem;
    letter-spacing: -0.03em;
    margin-bottom: 0.6rem;
  }
  .step__desc {
    font-size: 0.92rem;
    color: var(--muted);
    line-height: 1.6;
    max-width: 16rem;
  }

  @media (max-width: 860px) {
    .process__track {
      grid-template-columns: 1fr 1fr;
      gap: 3.5rem 1.5rem;
      padding-top: 0;
      border-top: none;
    }
    .step {
      padding-top: 3.6rem;
      border-top: 1px solid var(--line);
    }
    .step__num {
      top: -1.45rem;
    }
  }

  @media (max-width: 480px) {
    .process__track {
      grid-template-columns: 1fr;
    }
    .step__desc {
      max-width: none;
    }
  }
</style>
